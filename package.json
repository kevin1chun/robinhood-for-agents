{
  "name": "robinhood-for-agents",
  "version": "0.5.1",
  "type": "module",
  "description": "AI-native Robinhood trading interface — MCP server + TypeScript client",
  "license": "MIT",
  "author": "Kevin Chun",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevin1chun/robinhood-for-agents.git"
  },
  "homepage": "https://github.com/kevin1chun/robinhood-for-agents#readme",
  "bugs": "https://github.com/kevin1chun/robinhood-for-agents/issues",
  "keywords": [
    "robinhood",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "trading",
    "api-client",
    "typescript",
    "bun"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "robinhood-for-agents": "./bin/robinhood-for-agents.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    }
  },
  "files": ["src", "bin", "skills"],
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "playwright-core": "^1.50.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "latest",
    "msw": "^2.7.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "overrides": {
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
